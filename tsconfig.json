{
  "compilerOptions": {
    "target": "es2022",                                  
    "module": "NodeNext",                                
    "moduleResolution": "NodeNext",
    
    "outDir": "./dist",                                  
    "declaration": true,                                 
    
    "esModuleInterop": true,                             
    "forceConsistentCasingInFileNames": true,            
    "strict": true,                                      
    "skipLibCheck": true,
    
    "verbatimModuleSyntax": false                        
  },
  "include": ["index.ts"],
  "exclude": ["node_modules"]
}